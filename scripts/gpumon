#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VENV_DIR="${GPUMON_VENV:-"$ROOT/.venv"}"

if [[ ! -x "$VENV_DIR/bin/python" ]]; then
  echo "[gpumon] Project virtual environment not found."
  echo "[gpumon] Run: $ROOT/scripts/bootstrap"
  exit 1
fi

exec "$VENV_DIR/bin/python" -m gpumon "$@"
